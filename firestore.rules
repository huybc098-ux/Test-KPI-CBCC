rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - role: string (admin/user)
    //   - department: string
    //   - block: string
    //
    // Collection: tasks
    // Fields:
    //   - documentNumber: string
    //   - summary: string
    //   - documentDate: string
    //   - assignedDate: string
    //   - deadline: string
    //   - completionDate: string (optional)
    //   - status: string
    //   - assignee: string
    //   - assigneeUid: string (optional)
    //   - block: string
    //   - department: string
    //   - createdBy: string
    //   - createdAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "huybc098@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    function hasAllowedTaskFields(data) {
      // Allow only valid fields. Using hasOnly check.
      return data.keys().hasOnly(['documentNumber', 'summary', 'documentDate', 'assignedDate', 'deadline', 'completionDate', 'status', 'assignee', 'assigneeUid', 'block', 'department', 'createdBy', 'createdAt', 'evidenceDocumentNumber', 'evidenceDocumentDate']);
    }

    function isValidTask(data) {
      return data.keys().hasAll(['documentNumber', 'summary', 'deadline', 'status', 'createdBy', 'createdAt']) &&
             data.documentNumber is string && data.documentNumber.size() > 0 && data.documentNumber.size() < 100 &&
             data.summary is string && data.summary.size() > 0 && data.summary.size() < 2000 &&
             data.status in ['NOT_STARTED', 'IN_PROGRESS', 'COMPLETED', 'OVERDUE'] &&
             data.createdBy is string && data.createdBy.size() > 0 && data.createdBy.size() < 50 &&
             (!('evidenceDocumentNumber' in data) || data.evidenceDocumentNumber is string) &&
             (!('evidenceDocumentDate' in data) || data.evidenceDocumentDate is string) &&
             hasAllowedTaskFields(data);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin()) && request.resource.data.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTask(request.resource.data) && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && isValidTask(request.resource.data) && request.resource.data.createdBy == resource.data.createdBy && (resource.data.createdBy == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
    }
  }
}
